{
  "id": null,
  "uid": "soundremover-overview",
  "title": "SoundRemover Overview",
  "tags": ["soundremover", "microservices"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(soundremover_http_requests_total, service)",
        "includeAll": true,
        "multi": true,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP Throughput (req/s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(soundremover_http_requests_total{service=~\"$service\"}[5m])) by (service)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP Error Rate (%)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "100 * sum(rate(soundremover_http_requests_total{service=~\"$service\",status=~\"5..\"}[5m])) by (service) / clamp_min(sum(rate(soundremover_http_requests_total{service=~\"$service\"}[5m])) by (service), 0.0001)",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP Latency p95 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(soundremover_http_request_duration_seconds_bucket{service=~\"$service\"}[5m])) by (le, service))",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Queue Depth (RabbitMQ jobs)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rabbitmq_queue_messages{queue=~\"jobs\"}",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Queue Events (processing-service)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(soundremover_queue_events_total{service=\"processing-service\"}[5m])) by (event)",
          "legendFormat": "{{event}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Circuit Open State",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "soundremover_circuit_breaker_state{state=\"open\"}",
          "legendFormat": "{{service}} -> {{upstream}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Tracing Enabled",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "soundremover_tracing_enabled",
          "legendFormat": "{{service}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Jaeger Spans Received",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(jaeger_collector_spans_received_total[5m]))",
          "legendFormat": "spans/sec"
        }
      ]
    }
  ]
}
